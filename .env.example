# ============================================
# Keycloak Authentication Configuration
# ============================================

# Base URL aplikasi (default: localhost)
KEYCLOAK_BASE_URL=http://localhost

# URL server Keycloak (default: localhost dengan port 8080)
KEYCLOAK_SERVER_URL=http://localhost:8080

# Realm Keycloak (default: master)
KEYCLOAK_REALM=master

# Client ID aplikasi (default: admin-cli)
KEYCLOAK_CLIENT_ID=admin-cli

# Credentials user (default: admin/admin)
KEYCLOAK_USERNAME=admin
KEYCLOAK_PASSWORD=admin

# Redirect URI setelah autentikasi (default: localhost)
KEYCLOAK_REDIRECT_URI=http://localhost:3000/callback

# Execution ID untuk flow autentikasi (contoh default)
KEYCLOAK_EXECUTION_ID=12345678-1234-1234-1234-123456789012

# ============================================
# File Paths
# ============================================

# Lokasi file token (default: token.json)
TOKEN_FILE_PATH=token.json

# ============================================
# Optional: Additional Configuration
# ============================================

# Timeout dalam milidetik (default: 30000)
REQUEST_TIMEOUT=30000

# Debug mode (true/false - default: false)
DEBUG_MODE=false

# Proxy configuration (jika menggunakan proxy)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080